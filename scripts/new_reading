#!/usr/bin/env sh
set -eu

if [ "$#" -eq 0 ]; then
    echo "usage: ./scripts/new_reading \"reading name\"" >&2
    exit 1
fi

name="$*"

script_path="$0"
while [ -h "$script_path" ]; do
    script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"
    link_target="$(readlink "$script_path")"
    case "$link_target" in
        /*) script_path="$link_target" ;;
        *) script_path="$script_dir/$link_target" ;;
    esac
done

script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"
repo_root="$(CDPATH= cd -- "$script_dir/.." && pwd)"
readings_dir="$repo_root/docs/readings"

slug=$(
    printf '%s' "$name" |
    tr '[:upper:]' '[:lower:]' |
    sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
)

if [ -z "$slug" ]; then
    echo "error: reading name must contain at least one letter or number" >&2
    exit 1
fi

path="$readings_dir/$slug.md"
title=$(
    printf '%s' "$name" |
    sed 's/\\/\\\\/g; s/"/\\"/g'
)

if [ -e "$path" ]; then
    echo "error: $path already exists" >&2
    exit 1
fi

mkdir -p "$readings_dir"

cat > "$path" <<EOF
---
title: "$title"
link:
type:
date_read:
status:
topics:
related_issues:
priority:
---

# $name

## Core Idea


## What I Learned


## Relevance to This Project


## Action Items


## Open Questions


## Key Quote or Figure

EOF

echo "created $path"
