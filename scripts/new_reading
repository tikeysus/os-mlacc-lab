#!/usr/bin/env sh
set -eu

if [ "$#" -eq 0 ]; then
    echo "usage: ./scripts/new_reading \"reading name\" [paper.pdf]" >&2
    exit 1
fi

last_arg=
for arg do
    last_arg="$arg"
done

pdf_source=
case "$last_arg" in
    *.pdf|*.PDF)
        if [ "$#" -lt 2 ]; then
            echo "error: reading name is required when passing a PDF" >&2
            exit 1
        fi

        pdf_source="$last_arg"
        if [ ! -f "$pdf_source" ]; then
            echo "error: PDF not found: $pdf_source" >&2
            exit 1
        fi

        name=
        while [ "$#" -gt 1 ]; do
            if [ -z "$name" ]; then
                name="$1"
            else
                name="$name $1"
            fi
            shift
        done
        ;;
    *)
        name="$*"
        ;;
esac

script_path="$0"
while [ -h "$script_path" ]; do
    script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"
    link_target="$(readlink "$script_path")"
    case "$link_target" in
        /*) script_path="$link_target" ;;
        *) script_path="$script_dir/$link_target" ;;
    esac
done

script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"
repo_root="$(CDPATH= cd -- "$script_dir/.." && pwd)"
readings_dir="$repo_root/docs/readings"
template_path="$readings_dir/template.md"

if [ ! -f "$template_path" ]; then
    echo "error: missing reading template: $template_path" >&2
    exit 1
fi

slug=$(
    printf '%s' "$name" |
    tr '[:upper:]' '[:lower:]' |
    sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
)

if [ -z "$slug" ]; then
    echo "error: reading name must contain at least one letter or number" >&2
    exit 1
fi

reading_dir="$readings_dir/$slug"
notes_path="$reading_dir/notes.md"
pdf_path="$reading_dir/paper.pdf"
title=$(
    printf '%s' "$name" |
    sed 's/\\/\\\\/g; s/"/\\"/g'
)

if [ -e "$reading_dir" ]; then
    echo "error: $reading_dir already exists" >&2
    exit 1
fi

mkdir -p "$reading_dir"

awk -v title="$title" -v heading="$name" '
    $0 == "title:" {
        print "title: \"" title "\""
        next
    }
    $0 == "# Title" {
        print "# " heading
        next
    }
    { print }
' "$template_path" > "$notes_path"

if [ -n "$pdf_source" ]; then
    cp "$pdf_source" "$pdf_path"
fi

echo "created $notes_path"
if [ -n "$pdf_source" ]; then
    echo "copied $pdf_source -> $pdf_path"
else
    echo "add the paper PDF at $pdf_path"
fi
