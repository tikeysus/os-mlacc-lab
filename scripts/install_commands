#!/usr/bin/env sh
set -eu

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
repo_root="$(CDPATH= cd -- "$script_dir/.." && pwd)"
bin_dir="${HOME}/bin"

mkdir -p "$bin_dir"
ln -sf "$repo_root/scripts/new_reading" "$bin_dir/new_reading"

case ":$PATH:" in
    *":$bin_dir:"*)
        echo "installed new_reading -> $bin_dir/new_reading"
        ;;
    *)
        echo "installed new_reading -> $bin_dir/new_reading"
        echo "warning: $bin_dir is not on PATH in this shell" >&2
        echo "add this to your shell profile: export PATH=\"\$HOME/bin:\$PATH\"" >&2
        ;;
esac
